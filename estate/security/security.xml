<?xml version="1.0"?>
<odoo>
    <record id="res_groups_privilege_estate" model="res.groups.privilege">
        <field name="name">Estate!!!</field>
        <field name="sequence">12</field>
        <field name="category_id" ref="base.module_category_extra"/>
    </record>

    <record id="estate_group_user" model="res.groups">
        <field name="name">Agent</field>
        <!-- <field name="privilege_id" ref="base.module_category_real_estate_brokerage"/> -->
        <field name="privilege_id" ref="res_groups_privilege_estate"/>
    </record>
    <record id="estate_group_manager" model="res.groups">
        <field name="name">Manager</field>
        <!-- <field name="privilege_id" ref="base.module_category_real_estate_brokerage"/> -->
        <field name="privilege_id" ref="res_groups_privilege_estate"/>
        <field name="implied_ids" eval="[Command.link(ref('estate_group_user'))]"/>
    </record>

    <record id="estate_property_rule_agent" model="ir.rule">
        <field name="name">Agents: Own Properties Only</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="perm_unlink" eval="False"/>
        <field name="groups" eval="[Command.link(ref('estate_group_user'))]"/>
        <field name="domain_force">['|', ('seller_id', '=', user.id), ('seller_id', '=', 1)]</field>
    </record>
    <record id="estate_property_rule_manager" model="ir.rule">
        <field name="name">Managers: All Properties</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="perm_unlink" eval="False"/>
        <field name="groups" eval="[Command.link(ref('estate_group_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
    <record id="estate_property_rule_user_agency" model="ir.rule">
        <field name="name">Estate User will only acces their agency offers.</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="perm_unlink" eval="False"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('agency_id', 'in', company_ids)]</field>
    </record>
</odoo>
